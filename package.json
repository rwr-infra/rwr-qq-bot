{
    "name": "rwr-qq-bot",
    "version": "0.2.5",
    "description": "适用于 RWR 服务器数据查询的 QQ 机器人",
    "type": "module",
    "main": "index.js",
    "repository": {
        "url": "https://github.com/rwr-infra/rwr-qq-bot.git",
        "type": "git"
    },
    "homepage": "https://github.com/rwr-infra/rwr-qq-bot/blob/master/README.md",
    "bugs": {
        "url": "https://github.com/rwr-infra/rwr-qq-bot/issues"
    },
    "scripts": {
        "dev": "tsx watch --clear-screen=false src/index.ts",
        "start": "npm run build && node dist/app.js",
        "build": "node postbuild.cjs && rollup --environment NODE_ENV:production,BUILD:production --config rollup.config.cjs",
        "test": "vitest",
        "test:image": "RUN_IMAGE_TESTS=1 vitest -- src/services/imageRegression/imageRegression.test.ts",
        "test:watch": "vitest --watch",
        "coverage": "vitest --coverage"
    },
    "engines": {
        "node": ">=22.12.0",
        "npm": ">=10.9.0"
    },
    "keywords": [
        "qq",
        "bot",
        "self-hosted",
        "go-cqhttp",
        "rwr",
        "Running with rifles"
    ],
    "author": "Kreedzt",
    "license": "MIT",
    "dependencies": {
        "@fastify/static": "^9.1.2",
        "@resvg/resvg-js": "^2.6.2",
        "axios": "1.15.1",
        "cron": "^4.4.0",
        "dayjs": "^1.11.20",
        "dotenv": "^17.4.2",
        "echarts": "^6.0.0",
        "fast-xml-parser": "^5.7.1",
        "fastify": "^5.8.5",
        "jsonwebtoken": "^9.0.3",
        "lodash": "^4.18.1",
        "pg": "^8.20.0",
        "pinyin-match": "^1.2.10",
        "skia-canvas": "3.0.8",
        "tracer": "^1.3.0"
    },
    "devDependencies": {
        "@rollup/plugin-json": "^6.1.0",
        "@rollup/plugin-typescript": "^12.3.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/lodash": "^4.17.24",
        "@types/node": "^24.12.0",
        "@types/pg": "^8.20.0",
        "@vitest/coverage-istanbul": "^4.1.4",
        "@vitest/ui": "^4.1.4",
        "depcheck": "^1.4.7",
        "prettier": "^3.8.3",
        "rollup": "^4.60.2",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.9",
        "vite-plugin-node": "^8.0.0",
        "vitest": "^4.1.4",
        "vitest-sonar-reporter": "^3.0.0"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild",
            "skia-canvas"
        ]
    },
    "volta": {
        "node": "22.14.0",
        "npm": "10.9.0"
    }
}
